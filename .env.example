# Kiraaya Environment Variables Template
# Copy to .env.local and fill in real values
# NEVER commit .env.local to git

# ─────────────────────────────────────────────
# DATABASE
# AWS RDS PostgreSQL — ap-south-1 (Mumbai) for DPDP compliance
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://kiraaya_user:PASSWORD@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/kiraaya_prod?sslmode=require"

# ─────────────────────────────────────────────
# ENCRYPTION (generate with: openssl rand -hex 32)
# ─────────────────────────────────────────────
FIELD_ENCRYPTION_KEY="64-char-hex-string-generated-with-openssl-rand-hex-32"
JWT_SECRET="your-jwt-secret-minimum-32-chars"

# ─────────────────────────────────────────────
# RAZORPAY
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# ─────────────────────────────────────────────
# DIGIO (KYC, e-stamp, e-sign)
# ─────────────────────────────────────────────
DIGIO_BASE_URL="https://api.digio.in"
DIGIO_CLIENT_ID="your-digio-client-id"
DIGIO_CLIENT_SECRET="your-digio-client-secret"
DIGIO_WEBHOOK_SECRET="your-digio-webhook-secret"

# ─────────────────────────────────────────────
# SETU ACCOUNT AGGREGATOR
# ─────────────────────────────────────────────
SETU_AA_BASE_URL="https://fiu.setu.co"
SETU_CLIENT_ID="your-setu-client-id"
SETU_CLIENT_SECRET="your-setu-client-secret"

# ─────────────────────────────────────────────
# WHATSAPP (Gupshup)
# ─────────────────────────────────────────────
WHATSAPP_API_URL="https://api.gupshup.io/sm/api/v1/msg"
WHATSAPP_API_KEY="your-gupshup-api-key"
WHATSAPP_APP_NAME="kiraaya"

# ─────────────────────────────────────────────
# AWS S3
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-south-1"
S3_BUCKET_NAME="kiraaya-docs"

# ─────────────────────────────────────────────
# REDIS (ElastiCache)
# ─────────────────────────────────────────────
REDIS_URL="redis://your-elasticache-endpoint.ap-south-1.cache.amazonaws.com:6379"

# ─────────────────────────────────────────────
# MSG91 (OTP SMS)
# ─────────────────────────────────────────────
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_TEMPLATE_ID="your-otp-template-id"

# ─────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://app.kiraaya.in"
NEXT_PUBLIC_API_URL="https://api.kiraaya.in"
SCORE_MIN_PAYMENTS=3
NODE_ENV="production"
